# StreamMind AI - Environment Configurations

# OpenRouter API Key for chat summaries and streamer advice
# Obtain from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# KICK Developer Portal OAuth configuration (Phase 2 / Live Operations)
KICK_CLIENT_ID=your-kick-client-id-here
KICK_CLIENT_SECRET=your-kick-client-secret-here
KICK_REDIRECT_URI=http://localhost:3000/api/auth/callback/kick

# Local development WebSocket configuration
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
